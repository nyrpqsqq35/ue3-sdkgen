{
  "$schema": "https://raw.githubusercontent.com/microsoft/vscode-cmake-tools/refs/heads/main/schemas/CMakePresets-v10-schema.json",
  "version": 10,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 30,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "environment": {
        "VCPKG_INSTALLATION_ROOT": "C:\\src\\vcpkg"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang-cl.exe",
        "CMAKE_CXX_COMPILER": "clang-cl.exe",
        "CMAKE_EXPORT_COMPILE_COMMANDS": true,
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_INSTALLATION_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-win-llvm-lto-static-md",
        "VCPKG_HOST_TRIPLET": "x64-win-llvm-lto-static-md"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "description": "Debug",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "description": "Release",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },

    {
      "name": "ci",
      "binaryDir": "${sourceDir}/build",
      "inherits": "release"
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "debug"
    },
    {
      "name": "ci",
      "configurePreset": "ci"
    }
  ],
  "testPresets": [],
  "packagePresets": [],
  "vendor": {}
}
